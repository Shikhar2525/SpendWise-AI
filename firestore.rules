rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && resource != null && request.auth.uid == resource.data.uid;
    }

    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "shikhar.mandloi@gmail.com" && request.auth.token.email_verified == true);
    }

    // Rules for each collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    match /expenses/{id} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get, write: if isDocOwner() || isNewDocOwner() || isAdmin();
    }

    match /dues/{id} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get, write: if isDocOwner() || isNewDocOwner() || isAdmin();
    }

    match /salaries/{id} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get, write: if isDocOwner() || isNewDocOwner() || isAdmin();
    }

    match /budgets/{id} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get, write: if isDocOwner() || isNewDocOwner() || isAdmin();
    }

    match /goals/{id} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get, write: if isDocOwner() || isNewDocOwner() || isAdmin();
    }

    match /savings/{id} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get, write: if isDocOwner() || isNewDocOwner() || isAdmin();
    }

    // AI Chat History
    match /chats/{id} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get, write: if isDocOwner() || isNewDocOwner() || isAdmin();
    }

    // Allow the app to check connection status
    match /_connection_test_/{docId} {
      allow read: if true;
    }
  }
}
