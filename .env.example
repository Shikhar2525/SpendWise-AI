# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# SMTP_HOST: The hostname of your SMTP server (e.g., smtp.gmail.com, mail.privateemail.com)
SMTP_HOST=
# SMTP_PORT: Usually 587 (TLS) or 465 (SSL)
SMTP_PORT=587
# SMTP_USER: Your email account username
SMTP_USER=
# SMTP_PASS: Your email account password or App Password
SMTP_PASS=
# SMTP_SECURE: Set to true if using port 465, false otherwise
SMTP_SECURE=false
# SMTP_FROM: The "From" email address. Example: "SpendWise AI <notifications@yourdomain.com>"
SMTP_FROM=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
